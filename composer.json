{
    "name": "pivotphp/performance-tools",
    "description": "High-performance pooling, caching, and optimization tools for PivotPHP",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "PivotPHP Contributors",
            "email": "info@pivotphp.dev"
        }
    ],
    "require": {
        "php": "^8.1",
        "pivotphp/core": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "PivotPHP\\PerformanceTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PivotPHP\\PerformanceTools\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
